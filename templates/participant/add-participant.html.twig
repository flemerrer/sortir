{% extends 'base.html.twig' %}

{% block title %}Ajouter un participant{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{asset('styles/sorties.css')}}">
{% endblock %}

{% block body %}
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <h1>Ajouter un participant</h1>
            </div>
            <div class="col-md-12">
                <div class="row">
                    <div class="col-md-3"></div>
                    <div class="col-md-6 mb-5 container-read">
                        {{ form_start(participantForm) }}
                            <div class="group">
                                {{ form_label(participantForm.pseudo) }}
                                {{ form_widget(participantForm.pseudo) }}
                                {{ form_errors(participantForm.pseudo) }}
                            </div>
                            <div class="group">
                                {{ form_label(participantForm.nom) }}
                                {{ form_widget(participantForm.nom) }}
                                {{ form_errors(participantForm.nom) }}
                            </div>
                            <div class="group">
                                {{ form_label(participantForm.prenom) }}
                                {{ form_widget(participantForm.prenom) }}
                                {{ form_errors(participantForm.prenom) }}
                            </div>
                            <div class="group">
                                {{ form_label(participantForm.telephone) }}
                                {{ form_widget(participantForm.telephone) }}
                                {{ form_errors(participantForm.telephone) }}
                            </div>
                            <div class="group">
                                {{ form_label(participantForm.email) }}
                                {{ form_widget(participantForm.email) }}
                                {{ form_errors(participantForm.email) }}
                            </div>
                            <div class="group">
                                {{ form_label(participantForm.motdepasse) }}
                                {{ form_widget(participantForm.motdepasse) }}
                                {{ form_errors(participantForm.motdepasse) }}
                            </div>
                            <div class="group">
                                {{ form_label(participantForm.administrateur) }}
                                {{ form_widget(participantForm.administrateur) }}
                                {{ form_errors(participantForm.administrateur) }}
                            </div>
                            <div class="group">
                                {{ form_label(participantForm.actif) }}
                                {{ form_widget(participantForm.actif) }}
                                {{ form_errors(participantForm.actif) }}
                            </div>
                            <div class="group">
                                {{ form_label(participantForm.site) }}
                                {{ form_widget(participantForm.site) }}
                                {{ form_errors(participantForm.site) }}
                            </div>
                            <div class="d-flex justify-content-center">
                                <button class="btn-style m-2" type="submit">Enregistrer</button>
                            </div>
                            
                        {{ form_end(participantForm) }}
                    </div>
                    <div class="col-md-3"></div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}